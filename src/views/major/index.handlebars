<div>
  <h3>Lista de cursos</h3>
  <h4><a href="/majors/create"><i class="bi bi-plus-square"></i></a></h4>
</div>
<table class="table table-hover">
  <thead>
    <tr>
      <th scope="col">Código</th>
      <th scope="col">Nome</th>
    </tr>
  </thead>
  <tbody>
    {{#each majors}}
    <tr>
      <th scope="row">1</th>
      <td>{{code}}</td>
      <td>{{nome}}</td>
      <td class="text-end">
        <a href="/majors/read{{id}}"><i class="bi bi-eye"></i></a>
        <a href="/majors/update{{id}}"><i class="bi bi-pencil-square"></i></a>
        <a href="/majors/remove{{id}}" data-bs-toggle="modal" data-bs-target="remove-modal-{{id}}"><i class="bi bi-trash"></i></a>
      </td>
    </tr>
    {{#each}}
  </tbody>
</table>
{{#each majors}}
<div class="modal fade" id="remove-modal={{id}}" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Tem certeza?</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Queres deletar as informações este curso?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onlick={removeMajor('{{id}}')}>Confirmar</button>
      </div>
    </div>
  </div>
</div>
{{/each}}
